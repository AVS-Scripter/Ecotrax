rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    
    function isAuthenticated() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) { 
      return isAuthenticated() && request.auth.uid == userId; 
    }

    // Role extraction helper
    function getRole(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role;
    }

    // Optimized membership check using the denormalized array
    function isMember(communityId) {
      return isAuthenticated() && communityId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.joinedCommunities;
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if isAuthenticated(); // Typically users can read basic profiles
      allow create: if isOwner(userId) && !('joinedCommunities' in request.resource.data);
      
      // Prevent client from manually faking joined communities
      allow update: if isOwner(userId) 
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['joinedCommunities']);
      
      allow delete: if false; // Route via Cloud Function if needed
    }

    match /communities/{communityId} {
      // Visible if not soft-deleted
      allow read: if isAuthenticated() && resource.data.metadata.isDeleted == false;
      
      // Creation handled by CF
      allow create: if false; 
      
      // Only admins can update description/name. 
      // Cannot maliciously change memberCount or undo a soft delete.
      allow update: if getRole(communityId) == 'admin'
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['metadata', 'ownerId']);
      
      // All deletion is routed via Cloud Functions
      allow delete: if false; 

      match /members/{memberId} {
        allow read: if isMember(communityId);
        // Strict CF enforcement for joins/leaves/role changes
        allow write: if false; 
      }
      
      match /reports/{reportId} {
        // Members create their own reports.
        allow create: if isMember(communityId)
                      && request.resource.data.authorId == request.auth.uid;
                      
        // Only staff can read or act on reports.
        allow read, update, delete: if getRole(communityId) in ['admin', 'moderator'];
      }
    }

    match /invites/{inviteId} {
      // Only admins can see and manage the active invites for their community
      allow read: if getRole(resource.data.communityId) == 'admin';
      allow write: if false; // Creation/revocation managed via CF
    }

    match /global_stats/{docId} {
      allow read: if true;
      allow write: if false; // Managed by backend triggers
    }
  }
}
