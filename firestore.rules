rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    
    function isAuthenticated() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) { 
      return isAuthenticated() && request.auth.uid == userId; 
    }

    // Role extraction helper
    function getRole(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role;
    }

    // Optimized membership check using the denormalized array
    function isMember(communityId) {
      return isAuthenticated() && communityId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.joinedCommunities;
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      
      // Allow updates to joinedCommunities only if the user is participating in a join/leave flow.
      // We check that the user is updating their own profile.
      allow update: if isOwner(userId);
      
      allow delete: if false; 
    }

    match /communities/{communityId} {
      // Visible if not soft-deleted OR if you are the creator
      allow read: if isAuthenticated() && (resource.data.metadata.isDeleted == false || resource.data.createdBy == request.auth.uid);
      
      // Allow creation if authenticated. The transaction ensures consistency.
      allow create: if isAuthenticated() 
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.metadata.memberCount == 1;
      
      // Allow update by admins.
      // We allow updating metadata specifically for memberCount increments/decrements and isDeleted for soft-deletes.
      allow update: if isAuthenticated() && (
        getRole(communityId) == 'admin' || 
        // Allow incrementing memberCount when joining if everything else is valid
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['metadata']) && 
         request.resource.data.metadata.memberCount == resource.data.metadata.memberCount + 1) ||
        // Allow decrementing when leaving
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['metadata']) && 
         request.resource.data.metadata.memberCount == resource.data.metadata.memberCount - 1)
      );
      
      allow delete: if false; 

      match /members/{memberId} {
        allow read: if isAuthenticated(); // Allow reading members to see roles etc.

        // Allow joining: user creates their own member record
        allow create: if isAuthenticated() && memberId == request.auth.uid;

        // Allow leave: user deletes their own member record
        allow delete: if isAuthenticated() && memberId == request.auth.uid;

        // Role changes: only admins can update roles
        allow update: if getRole(communityId) == 'admin';
      }
    }

    match /reports/{reportId} {
      // Members create reports for their community
      allow create: if isMember(request.resource.data.communityId)
                      && request.resource.data.userId == request.auth.uid;

      // Members can read reports in their community. Staff can manage.
      allow read: if isMember(resource.data.communityId);
      allow update, delete: if getRole(resource.data.communityId) in ['admin', 'moderator'];
    }

    match /invites/{inviteId} {
      // Allow reading and validating invites
      allow read: if isAuthenticated();
      
      // Admins can create invites for their community. 
      // We also allow the creator of a community to create an invite in the same transaction.
      allow create: if isAuthenticated() && (
        (request.resource.data.communityId != null && 
         getAfter(/databases/$(database)/documents/communities/$(request.resource.data.communityId)).data.createdBy == request.auth.uid) ||
        getRole(request.resource.data.communityId) == 'admin'
      );
      
      // Allow incrementing usedCount when using an invite
      allow update: if isAuthenticated() && (
        getRole(resource.data.communityId) == 'admin' ||
        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['usedCount', 'isActive']) && 
         request.resource.data.usedCount == resource.data.usedCount + 1)
      );
    }

    match /global_stats/{docId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Allow stats updates from client triggers if needed
    }
  }
}
